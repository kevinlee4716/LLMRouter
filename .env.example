# LLMRouter configuration
# Copy this file to .env and fill in your values.

# AES-256-GCM encryption key for API key storage.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required for production. When unset in development, a key is auto-generated.
ENCRYPTION_KEY=your-64-char-hex-key-here

# Server port (default: 2210)
PORT=2210

# Network interface the server listens on.
# Default '::' (dual-stack IPv4+IPv6).
# Set 127.0.0.1 to restrict to localhost.
# HOST=::

# Max /v1 proxy requests per minute per client IP (default: 120).
# Set to 0 to disable proxy rate limiting.
# PROXY_RATE_LIMIT_RPM=120

# Per-provider daily request cap:
# PROVIDER_DAILY_REQUEST_CAP_OPENROUTER=50

# Wall-clock budget for provider failover, in milliseconds (default: 45000).
# FALLBACK_TIME_BUDGET_MS=45000

# Opt-in response cache (default: false).
# RESPONSE_CACHE=false
# RESPONSE_CACHE_TTL_SECONDS=3600
# RESPONSE_CACHE_MAX_TEMPERATURE=1.0
# RESPONSE_CACHE_MAX_ENTRIES=5000

# Block private/loopback URLs as custom provider base URLs.
# Recommended when hosting on a VPS or shared network.
# LLMROUTER_BLOCK_PRIVATE_PROVIDER_URLS=true

# Request analytics retention.
REQUEST_ANALYTICS_RETENTION_DAYS=90
REQUEST_ANALYTICS_MAX_ROWS=100000

# Record client IP + User-Agent in request analytics (default: true).
# REQUEST_ANALYTICS_LOG_CLIENT=true

# Optional SQLite location override.
# LLMROUTER_DB_PATH=/path/to/llmrouter.db

# Context handoff on model switch.
# LLMROUTER_CONTEXT_HANDOFF=on_model_switch

# Comma-separated extra origins allowed to call the API from a browser.
# DASHBOARD_ORIGINS=http://my-server.local

# Declarative startup config (JSON file or inline JSON).
# LLMROUTER_CONFIG_PATH=/path/to/llmrouter.config.json
# LLMROUTER_CONFIG_JSON={"keys":[{"platform":"groq","key":"gsk_...","label":"main"}],"routing":{"strategy":"balanced"}}
